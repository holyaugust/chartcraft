# DeepSeek（文档 AI 校对）
# 开发环境：推荐在项目根目录创建 .env.local，仅配置 DEEPSEEK_API_KEY（由 Vite 代理注入，不会打进前端包）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# 生产/直连：需在前端配置（会打进构建产物，仅适合内网或私有部署）
# VITE_DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# VITE_DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
# VITE_DEEPSEEK_MODEL=deepseek-chat

# 智能图形图片识图（可选）：官方 deepseek-chat 不支持 image_url，默认走浏览器 OCR + 文本 AI
# 若你有支持多模态的 OpenAI 兼容端点，可显式开启：
# VITE_DEEPSEEK_VISION_ENABLED=true
# VITE_DEEPSEEK_VISION_MODEL=your-vision-model
